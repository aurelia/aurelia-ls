          "actionName": "sortByTitle",
          "methodBodyStatements": "this.taskItems.sort((left, right) => left.title.localeCompare(right.title));\nthis.taskItemsPage = 1;"
        },
        {
          "targetRef": {
            "kind": "application-pattern",
            "domain": "application-pattern",
            "id": "domain-command-action"
          },
          "actionName": "deleteSelectedTaskItems",
          "methodBodyStatements": "const selectedIds = new Set(this.selectedTaskItemIds);\nfor (let index = this.taskItems.length - 1; index >= 0; index -= 1) {\n  if (selectedIds.has(this.taskItems[index]!.id)) {\n    this.taskItems.splice(index, 1);\n  }\n}\nthis.selectedTaskItemIds = [];\nthis.taskItemsPage = Math.min(this.taskItemsPage, this.taskItemsPageCount);"
        }
