{
  "name": "@aurelia-ls/semantic-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/index.js",
  "types": "./out/index.d.ts",
  "exports": {
    ".": {
      "import": "./out/index.js",
      "types": "./out/index.d.ts"
    }
  },
  "engines": {
    "node": ">=23 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true }); require('node:fs').rmSync('tsconfig.tsbuildinfo', { force: true })\"",
    "contract:proxy-observation": "pnpm build && node scripts/contract-proxy-observation.mjs",
    "contract:computed-observer-source": "pnpm build && node scripts/contract-computed-observer-source.mjs",
    "contract:expression-object-literal-shorthand": "pnpm build && node scripts/contract-expression-object-literal-shorthand.mjs",
    "contract:node-observer-service-customization": "pnpm build && node scripts/contract-node-observer-service-customization.mjs",
    "contract:observer-locator-target-access": "pnpm build && node scripts/contract-observer-locator-target-access.mjs",
    "contract:one-hop-forwarding-accessor": "pnpm build && node scripts/contract-one-hop-forwarding-accessor.mjs",
    "contract:proxy-observable-escapes": "pnpm build && node scripts/contract-proxy-observable-escapes.mjs",
    "contract:router-dynamic-pattern": "pnpm build && node scripts/contract-router-dynamic-pattern.mjs",
    "contract:runtime-watcher-expression-source": "pnpm build && node scripts/contract-runtime-watcher-expression-source.mjs",
    "contract:runtime-effect-observation": "pnpm build && node scripts/contract-runtime-effect-observation.mjs",
    "contract:runtime-composition-bound-controller": "pnpm build && node scripts/contract-runtime-composition-bound-controller.mjs",
    "contract:select-checked-value-channels": "pnpm build && node scripts/contract-select-checked-value-channels.mjs",
    "contract:template-diagnostics": "pnpm build && node scripts/contract-template-diagnostics.mjs",
    "contract:template-collection-observation": "pnpm build && node scripts/contract-template-collection-observation.mjs",
    "contract:trackable-method-observation": "pnpm build && node scripts/contract-trackable-method-observation.mjs",
    "contract:suite": "node scripts/contract-suite.mjs",
    "fixtures:authoring": "pnpm build && node scripts/materialize-authoring-fixtures.mjs",
    "check:authoring-fixtures": "node scripts/typecheck-authoring-fixtures.mjs",
    "pressure:app-api": "pnpm build && node scripts/app-api-pressure.mjs",
    "pressure:cursor-loci": "pnpm build && node scripts/cursor-locus-pressure.mjs",
    "profile:app-telemetry": "pnpm build && node --expose-gc scripts/app-telemetry.mjs",
    "smoke:catalog-storefront": "pnpm build && node scripts/smoke-authoring-catalog-storefront.mjs",
    "smoke:composed-dashboard": "pnpm build && node scripts/smoke-authoring-composed-dashboard.mjs",
    "smoke:localized-state-backed-form": "pnpm build && node scripts/smoke-authoring-localized-state-backed-form.mjs",
    "smoke:minimal-app": "pnpm build && node scripts/smoke-authoring-minimal-app.mjs",
    "smoke:repair-plan": "pnpm build && node scripts/smoke-authoring-repair-plan.mjs",
    "smoke:service-backed-form": "pnpm build && node scripts/smoke-authoring-service-backed-form.mjs",
    "smoke:storefront": "pnpm build && node scripts/smoke-authoring-storefront.mjs",
    "smoke:validated-state-backed-form": "pnpm build && node scripts/smoke-authoring-validated-state-backed-form.mjs",
    "smoke:routed-state-backed-form": "pnpm build && node scripts/smoke-authoring-routed-state-backed-form.mjs",
    "smoke:state-backed-form": "pnpm build && node scripts/smoke-authoring-state-backed-form.mjs",
    "smoke:state-store-todo": "pnpm build && node scripts/smoke-authoring-state-store-todo.mjs",
    "test": "pnpm build"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.5.4"
  }
}
