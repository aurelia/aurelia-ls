{
  "name": "@aurelia-ls/atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "atlas-session-daemon": "./dist/session/daemon.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./evaluation": "./dist/evaluation/index.js",
    "./framework": "./dist/framework/index.js",
    "./inquiry": "./dist/inquiry/index.js",
    "./inquiry/runtime": "./dist/inquiry/runtime/index.js",
    "./session": "./dist/session/index.js",
    "./source": "./dist/source/index.js"
  },
  "engines": {
    "node": ">=23 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "orient": "pnpm build && node dist/scripts/orient.js",
    "orient:json": "pnpm build && node dist/scripts/orient.js --json",
    "memory": "pnpm build && node dist/scripts/atlas-memory.js",
    "memory:json": "pnpm build && node dist/scripts/atlas-memory.js --json",
    "memory:next": "pnpm build && node dist/scripts/atlas-memory.js --projection=next --detail",
    "memory:write": "pnpm build && node dist/scripts/atlas-memory-write.js",
    "self": "pnpm build && node dist/scripts/atlas-self.js",
    "work:router": "pnpm build && node dist/scripts/atlas-work-router.js",
    "work:router:json": "pnpm build && node dist/scripts/atlas-work-router.js --json",
    "bridge:aulink": "pnpm build && node dist/scripts/bridge-aulink.js",
    "framework:errors": "pnpm build && node dist/scripts/framework-errors.js",
    "framework:evaluator": "pnpm build && node dist/scripts/framework-evaluator.js",
    "framework:observation": "pnpm build && node dist/scripts/framework-observation.js",
    "framework:resources": "pnpm build && node dist/scripts/framework-resources.js",
    "framework:corpus": "pnpm build && node dist/scripts/framework-corpus.js",
    "framework:router": "pnpm build && node dist/scripts/framework-router.js",
    "playground:inquiry": "pnpm build && node dist/scripts/inquiry-playground.js",
    "product:architecture": "pnpm build && node dist/scripts/product-architecture.js",
    "profile:product-architecture": "pnpm build && node dist/scripts/product-architecture-profile.js",
    "profile:product-architecture:detail": "pnpm build && node dist/scripts/product-architecture-profile.js --detail",
    "profile:self": "pnpm build && node dist/scripts/atlas-self-profile.js",
    "profile:self:detail": "pnpm build && node dist/scripts/atlas-self-profile.js --detail",
    "pressure:self": "pnpm build && node dist/scripts/atlas-self-pressure.js",
    "pressure:self:detail": "pnpm build && node dist/scripts/atlas-self-pressure.js --detail",
    "pressure:product-architecture": "pnpm build && node dist/scripts/product-architecture-pressure.js",
    "pressure:product-architecture:detail": "pnpm build && node dist/scripts/product-architecture-pressure.js --detail",
    "pressure:framework-resources": "pnpm build && node dist/scripts/framework-resources-pressure.js",
    "pressure:framework-corpus": "pnpm build && node dist/scripts/framework-corpus-pressure.js",
    "pressure:framework-observation": "pnpm build && node dist/scripts/framework-observation-pressure.js",
    "pressure:bridge-aulink": "pnpm build && node dist/scripts/bridge-aulink-pressure.js",
    "pressure:framework-errors": "pnpm build && node dist/scripts/framework-errors-pressure.js",
    "pressure:framework-router": "pnpm build && node dist/scripts/framework-router-pressure.js",
    "pressure:plugin-architecture": "pnpm build && node dist/scripts/plugin-architecture-pressure.js",
    "pressure:workspace-architecture": "pnpm build && node dist/scripts/workspace-architecture-pressure.js",
    "profile:workspace-architecture": "pnpm build && node dist/scripts/workspace-architecture-profile.js",
    "report:framework-emulation": "pnpm build && node dist/scripts/framework-emulation-symbols-report.js",
    "session:ensure": "pnpm build && node dist/scripts/inquiry-session-ensure.js",
    "session:playground": "pnpm build && node dist/scripts/inquiry-session-playground.js",
    "session:shutdown": "pnpm build && node dist/scripts/inquiry-session-shutdown.js",
    "self-check": "pnpm build && node dist/scripts/self-check.js",
    "smoke": "pnpm self-check"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
