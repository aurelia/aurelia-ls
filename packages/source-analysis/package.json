{
  "name": "@aurelia-ls/source-analysis",
  "version": "0.0.0",
  "description": "Structural analysis over a TypeScript codebase — deterministic, bounded queries designed for AI orientation",
  "type": "module",
  "main": "./out/index.js",
  "types": "./out/index.d.ts",
  "bin": {
    "source-analysis": "./out/cli.js"
  },
  "exports": {
    ".": {
      "import": "./out/index.js",
      "types": "./out/index.d.ts"
    },
    "./snapshots": {
      "import": "./out/public/snapshots.js",
      "types": "./out/public/snapshots.d.ts"
    },
    "./host": {
      "import": "./out/public/host.js",
      "types": "./out/public/host.d.ts"
    },
    "./profile": {
      "import": "./out/public/profile.js",
      "types": "./out/public/profile.d.ts"
    },
    "./structural": {
      "import": "./out/public/structural.js",
      "types": "./out/public/structural.d.ts"
    }
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:tests": "node ./scripts/build-tests.mjs",
    "generate:aurelia-di-interface-goldens": "node ./scripts/generate-aurelia-di-interface-goldens.mjs",
    "generate:aurelia-framework-goldens": "node ./scripts/generate-aurelia-framework-goldens.mjs",
    "preflight": "node ./scripts/preflight.mjs",
    "test": "node ./scripts/build.mjs && node ./scripts/build-tests.mjs && node ./scripts/run-node-tests.mjs",
    "test:node:aurelia-di-interface-goldens": "node ./scripts/run-node-tests.mjs out-test/test/aurelia-di-interface-goldens.test.js",
    "test:node": "node ./scripts/run-node-tests.mjs",
    "test:node:aurelia-framework-exports": "node ./scripts/run-node-tests.mjs test/aurelia-framework-exports.test.ts",
    "test:node:cov": "node ./scripts/run-node-tests.mjs --coverage"
  },
  "peerDependencies": {
    "typescript": "^5.5.4"
  }
}
